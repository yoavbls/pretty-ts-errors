{
  "name": "@pretty-ts-errors/vscode-formatter",
  "version": "0.1.0",
  "type": "module",
  "description": "Pretty TypeScript Errors Formatter for VSCode hovers",
  "files": [
    "src/**",
    "dist/**"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CyberT33N/pretty-ts-errors.git"
  },
  "keywords": [
    "typescript",
    "errors"
  ],
  "author": "CyberT33N",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/CyberT33N/pretty-ts-errors/issues"
  },
  "homepage": "https://github.com/CyberT33N/pretty-ts-errors#readme",
  "devDependencies": {
    "@vitest/coverage-v8": "catalog:",
    "vitest": "catalog:"
  },
  "dependencies": {
    "@pretty-ts-errors/error-translator": "workspace:*",
    "@pretty-ts-errors/formatter": "workspace:*",
    "@pretty-ts-errors/utils": "workspace:*",
    "vscode-languageserver-types": "catalog:",
    "vscode-uri": "catalog:"
  }
}
