{
  /**
   * Thin artifact leaf for the `@pretty-ts-errors/utils` package as a
   * runtime-bearing shared package delivered as an unbundled package artifact.
   */
  "$schema": "https://json.schemastore.org/tsconfig",

  /**
   * Reuse the specialized shared-package artifact role instead of redefining
   * artifact semantics locally.
   */
  "extends": "../../tsconfig.shared-package-artifact.base.json",

  "compilerOptions": {
    /**
     * The artifact leaf alone knows its concrete source root.
     */
    "rootDir": "./src",

    /**
     * Package artifacts are emitted into the leaf-local distribution lane.
     */
    "outDir": "./dist"
  },

  /**
   * The artifact lane covers production-facing TypeScript package sources only.
   */
  "include": ["src/**/*.ts"]
}
